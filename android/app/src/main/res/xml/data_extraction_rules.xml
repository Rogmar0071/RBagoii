<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules for Android 12+ (API 31+).
  This defines what data is backed up to the cloud and what is included in
  device-to-device transfers.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Include shared preferences -->
        <include domain="sharedpref" path="chat_prefs.xml"/>
        <include domain="sharedpref" path="home_conversations.xml"/>

        <!-- Exclude sensitive data -->
        <exclude domain="sharedpref" path="device_prefs.xml"/>
    </cloud-backup>

    <device-transfer>
        <!-- Same rules for device transfer -->
        <include domain="sharedpref" path="chat_prefs.xml"/>
        <include domain="sharedpref" path="home_conversations.xml"/>
        <exclude domain="sharedpref" path="device_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>
